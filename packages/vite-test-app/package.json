{
  "name": "vite-test-app",
  "version": "0.0.0",
  "private": true,
  "description": "Small description for vite-test-app goes here",
  "repository": "",
  "license": "MIT",
  "author": "",
  "exports": {
    "./app.js": "./dist/app.js",
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "prepare": "vite build",
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"npm:lint:*(!fix)\" --names \"lint:\" --prefixColors auto",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "concurrently \"npm:lint:css -- --fix\"",
    "lint:fix": "concurrently \"npm:lint:*:fix\" --names \"fix:\" --prefixColors auto && npm run format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "start": "vite"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/eslint-parser": "^7.28.6",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/runtime": "^7.29.2",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.2",
    "@ember/test-waiters": "^4.1.1",
    "@embroider/compat": "^4.1.17",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.4.7",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.2",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.2",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^2.1.1",
    "@rollup/plugin-babel": "^7.0.0",
    "babel-plugin-ember-template-compilation": "^3.1.0",
    "concurrently": "^9.2.1",
    "decorator-transforms": "^2.3.2",
    "ember-cli": "~6.12.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-deprecation-workflow": "^4.0.1",
    "ember-load-initializers": "^3.0.1",
    "ember-modifier": "^4.3.0",
    "ember-page-title": "^9.0.3",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.0.0",
    "ember-template-lint": "^7.9.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^16.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-ember-template-tag": "^2.1.5",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^38.0.0",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">= 20.19.0"
  },
  "ember": {
    "edition": "octane"
  }
}
