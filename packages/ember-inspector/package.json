{
  "name": "ember-inspector",
  "version": "4.17.0",
  "description": "Extends developer tools to allow you to better inspect your Ember.js apps.",
  "repository": "https://github.com/emberjs/ember-inspector",
  "license": "MIT",
  "author": "Tilde, Inc.",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "exports": {
    ".": "./dist/",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "ember build",
    "build:production": "ember build --environment production",
    "lint": "pnpm \"/^lint:(?!fix$)[^:]+$/\"",
    "lint:css": "stylelint \"**/*.scss\"",
    "lint:css:fix": "stylelint \"**/*.scss\" --fix",
    "lint:fix": "pnpm \"/^lint:[^:]+:fix$/\" && pnpm format",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:format": "prettier --cache --check \"**/*.{js,cjs,mjs}\"",
    "format": "prettier --cache --write \"**/*.{js,cjs,mjs}\"",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lock-version": "pnpm build:production && pnpm panes:compress",
    "prepare": "pnpm build:production",
    "prepublishOnly": "node -e 'process.exit(!require(\"fs\").existsSync(\"./dist\"))' || pnpm build:production",
    "serve:bookmarklet": "ember serve --port 9191",
    "start": "ember serve",
    "test": "ember test",
    "watch": "ember build --watch",
    "watch-test": "ember test --serve"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/eslint-parser": "^7.25.9",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@ember/edition-utils": "^1.2.0",
    "@ember/legacy-built-in-components": "^0.4.2",
    "@ember/optional-features": "^2.2.0",
    "@ember/render-modifiers": "^2.1.0",
    "@ember/string": "^4.0.0",
    "@ember/test-helpers": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "@html-next/vertical-collection": "^4.0.2",
    "backburner.js": "^2.8.0",
    "basiccontext": "^3.5.1",
    "broccoli-asset-rev": "^3.0.0",
    "broccoli-babel-transpiler": "^8.0.2",
    "broccoli-concat": "^4.2.5",
    "broccoli-funnel": "^3.0.8",
    "broccoli-merge-trees": "^4.2.0",
    "broccoli-stew": "^3.0.0",
    "broccoli-string-replace": "^0.1.2",
    "compare-versions": "^6.1.1",
    "ember-auto-import": "^2.10.0",
    "ember-cli": "~6.1.0",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-cors": "^0.0.2",
    "ember-cli-deprecation-workflow": "^2.2.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sass": "^11.0.1",
    "ember-cli-showdown": "^10.0.0",
    "ember-cli-terser": "^4.0.2",
    "ember-cli-version-checker": "^5.1.2",
    "ember-concurrency": "^3.1.1",
    "ember-debug": "workspace:*",
    "ember-decorators": "^6.1.1",
    "ember-event-helpers": "^0.1.1",
    "ember-flatpickr": "^4.0.0",
    "ember-in-element-polyfill": "^1.0.1",
    "ember-load-initializers": "^3.0.1",
    "ember-math-helpers": "^4.0.0",
    "ember-modifier": "^4.2.0",
    "ember-on-resize-modifier": "^1.1.0",
    "ember-qunit": "^8.1.1",
    "ember-resolver": "^13.1.0",
    "ember-sinon-qunit": "^7.5.0",
    "ember-source": "^5.0.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-svg-jar": "^2.6.0",
    "ember-table": "^5.0.6",
    "ember-template-lint": "^6.0.0",
    "ember-test-selectors": "^6.0.0",
    "ember-truth-helpers": "^3.1.1",
    "ember-try": "^3.0.0",
    "ember-wormhole": "^0.6.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^15.14.0",
    "loader.js": "^4.7.0",
    "normalize.css": "8.0.1",
    "pretender": "^3.4.7",
    "prettier": "^3.4.2",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "qunit": "^2.23.1",
    "qunit-dom": "^3.4.0",
    "sass": "^1.79.4",
    "showdown": "^2.1.0",
    "stylelint": "^16.13.2",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-prettier": "^5.0.2",
    "tracked-built-ins": "^3.4.0",
    "tracked-toolbox": "^2.0.0",
    "webpack": "^5.97.1"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "ember": {
    "edition": "octane"
  },
  "emberVersionsSupported": [
    "3.16.0",
    ""
  ],
  "previousEmberVersionsSupported": [
    "0.0.0",
    "2.7.0",
    "3.4.0"
  ],
  "release-it": {
    "plugins": {
      "release-it-lerna-changelog": {
        "infile": "CHANGELOG.md",
        "launchEditor": true
      }
    },
    "git": {
      "tagName": "v${version}"
    },
    "github": {
      "release": false,
      "tokenRef": "GITHUB_AUTH"
    },
    "npm": {
      "publish": false
    }
  }
}
